# ══════════════════════════════════════════════════════════════════════════════
#  Real Estate Economy Analysis Service — .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── Environment & Secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
secrets/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
*.egg-link
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
.env/
.python-version

# pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
nosetests.xml
pytest.xml

# mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Ruff / linting
.ruff_cache/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Build output
frontend/dist/
frontend/build/
frontend/.next/
frontend/out/
frontend/.nuxt/
frontend/.output/
frontend/.vite/

# Testing
frontend/coverage/

# Cache
.eslintcache
.stylelintcache
*.tsbuildinfo

# ── Docker ────────────────────────────────────────────────────────────────────
# Do not ignore docker-compose.yml or Dockerfiles — they are version-controlled.
# Ignore any local override files.
docker-compose.override.yml
docker-compose.local.yml
.docker/

# ── ML Models & Large Files ───────────────────────────────────────────────────
# Fine-tuned model weights (can be several GB)
backend/app/ml/models/finetuned/
backend/app/ml/models/*.bin
backend/app/ml/models/*.safetensors
backend/app/ml/models/*.pt
backend/app/ml/models/*.onnx
*.ckpt
*.pth

# HuggingFace cache
.cache/huggingface/

# ── Database & Persistent Data ────────────────────────────────────────────────
*.sqlite3
*.db
postgres_data/
chromadb_data/
redis_data/

# Alembic auto-generated (keep migrations, ignore local state)
backend/alembic/versions/__pycache__/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ── OS & Editor ───────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

.idea/
.vscode/
*.swp
*.swo
*~

# ── Misc ──────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.tmp/
tmp/
