# ══════════════════════════════════════════════════════════════════════════════
#  Real Estate Economy Analysis Service — Environment Variables
#  Copy this file to .env and fill in your actual values.
#  NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Full async-compatible DSN used by SQLAlchemy (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/realestate

# Credentials used by the postgres container itself
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=realestate

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used for task queues (Celery / ARQ) and response caching
REDIS_URL=redis://redis:6379/0

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# Vector store for property embeddings and RAG retrieval
# Host name matches the docker-compose service name; port is the container-internal port
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000

# ── Public Data Portal API ────────────────────────────────────────────────────
# 국토교통부 실거래가 API, 건축물대장 API, etc.
# Apply at: https://www.data.go.kr/
PUBLIC_DATA_API_KEY=your_api_key_here

# ── Naver Maps / Local API ────────────────────────────────────────────────────
# Used for geocoding and Points-of-Interest queries
# Apply at: https://developers.naver.com/
NAVER_CLIENT_ID=your_client_id
NAVER_CLIENT_SECRET=your_client_secret

# ── LLM / ML Models ──────────────────────────────────────────────────────────
# Path to the fine-tuned LLM weights (relative to backend working directory)
# This path is mounted as a Docker volume (model_data) in docker-compose.yml
LLM_MODEL_PATH=./app/ml/models/finetuned

# HuggingFace model ID used for generating property/document embeddings
# Requires ~2 GB GPU/CPU memory; swap to a smaller model for low-resource envs
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-large

# ── Application ───────────────────────────────────────────────────────────────
# Set to "production" | "development" | "testing"
APP_ENV=development

# Secret key for JWT signing — generate with: openssl rand -hex 32
SECRET_KEY=change_me_to_a_long_random_string

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
