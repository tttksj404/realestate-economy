# Real Estate Economy Service — Environment Variables
# Copy to .env and fill in your values: cp .env.example .env

# -----------------------------------------------------------------------------
# Runtime mode
# -----------------------------------------------------------------------------
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Optional: API key for endpoint protection. Leave empty to disable auth.
API_KEY=

# Comma-separated allowed origins (production: your frontend domain)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# Database (Docker default)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=realestate
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/realestate

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# ChromaDB
# -----------------------------------------------------------------------------
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000
CHROMADB_EXTERNAL_PORT=8100
CHROMADB_PATH=./chroma_db

# -----------------------------------------------------------------------------
# Model / ML
# -----------------------------------------------------------------------------
LLM_MODEL_PATH=./app/ml/models/finetuned
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-large

# -----------------------------------------------------------------------------
# Data source credentials (required for data collection)
# Get API keys from https://www.data.go.kr and https://openapi.onbid.co.kr
# -----------------------------------------------------------------------------
PUBLIC_DATA_API_KEY_APT=
PUBLIC_DATA_API_KEY_SMALL=
PUBLIC_DATA_API_KEY_TOGETHER=
PUBLIC_DATA_API_KEY_OFFICE=
ONBID_API_KEY=

# 한국부동산원 R-ONE API (https://www.reb.or.kr/r-one/)
KOREA_REAL_ESTATE_KEY=

# -----------------------------------------------------------------------------
# Scheduler (daily data collection)
# -----------------------------------------------------------------------------
ENABLE_SCHEDULER=true
SCHEDULER_HOUR=6
SCHEDULER_MINUTE=0
SCHEDULER_TIMEZONE=Asia/Seoul
SCHEDULER_SOURCE=all
SCHEDULER_MONTHS=3

# -----------------------------------------------------------------------------
# Service ports
# -----------------------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=3000

# -----------------------------------------------------------------------------
# Uvicorn workers (production: 2-4)
# -----------------------------------------------------------------------------
WEB_CONCURRENCY=1
