# Real Estate Economy Service environment template
# Copy to .env and fill in secrets. Do not commit .env.

# -----------------------------------------------------------------------------
# Runtime mode
# -----------------------------------------------------------------------------
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
SECRET_KEY=change_me_to_a_long_random_string
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# Database (Docker default)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=realestate
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/realestate

# Local (non-Docker) example:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/realestate

# -----------------------------------------------------------------------------
# Cache / queue
# -----------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Local (non-Docker) example:
# REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# ChromaDB
# -----------------------------------------------------------------------------
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000
CHROMADB_EXTERNAL_PORT=8100
CHROMADB_PATH=./chroma_db

# Local (non-Docker) example:
# CHROMADB_HOST=localhost
# CHROMADB_PORT=8100

# -----------------------------------------------------------------------------
# Model / ML
# -----------------------------------------------------------------------------
LLM_MODEL_PATH=./app/ml/models/finetuned
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-large

# -----------------------------------------------------------------------------
# Data source credentials (required in production)
# - 공공데이터포털: https://www.data.go.kr (국토부 실거래가 API)
# - 온비드: https://openapi.onbid.co.kr (캠코 공매 물건 API)
# -----------------------------------------------------------------------------
PUBLIC_DATA_API_KEY=your_data_go_kr_api_key
ONBID_API_KEY=your_onbid_api_key

# -----------------------------------------------------------------------------
# Backend scheduler (daily data collection)
# -----------------------------------------------------------------------------
ENABLE_SCHEDULER=true
SCHEDULER_HOUR=6
SCHEDULER_MINUTE=0
SCHEDULER_TIMEZONE=Asia/Seoul
SCHEDULER_SOURCE=all
SCHEDULER_MONTHS=3

# -----------------------------------------------------------------------------
# Service ports
# -----------------------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=3000
